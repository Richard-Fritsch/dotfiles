" activate colors
let g:gruvbox_contrast_dark = 'hard'
autocmd vimenter * ++nested colorscheme gruvbox
set background=dark
syntax enable

" Spaces & Tabs
set tabstop=4
set shiftwidth=4
set softtabstop=4 
set expandtab
set smarttab        
 
" UI config
set number
set relativenumber
set cursorline
filetype plugin on
filetype indent on
set lazyredraw
set wildmenu
set showmatch
set mat=2
set cmdheight=1
set magic
set foldcolumn=1

" Search config
set hlsearch
set incsearch
set ignorecase      
set smartcase 



set backspace=2
 
set autoindent
 
set formatoptions=c,q,r,t 

set ruler           

set mouse=a         " Enable the use of the mouse.
