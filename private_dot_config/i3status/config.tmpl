# i3status configuration file.
# see "man i3status" for documentation.

general {
        colors = true
        interval = 1
}

{{ if ( eq .chezmoi.hostname "rich-desktop" ) }}order += "ethernet _first_"
{{ else if ( eq .chezmoi.hostname "rich-rog" ) }}order += "wireless _first_"{{end}}
order += "disk /"
order += "disk /home/"
order += "load"
order += "memory"
order += "tztime local"
{{ if ( eq .chezmoi.hostname "rich-desktop" ) }}
ethernet _first_ {
    format_up = "E: %ip (%speed)"
    format_down = "E: down"
}
{{ else if ( eq .chezmoi.hostname "rich-rog" ) }}
wireless _first_ {
    format_up = "W: (%quality at %essid) %ip"
    format_down = "W: down"
}

battery all {
    format = "%status %percentage %remaining"
}
{{ end }}
disk "/" {
    format = "%avail"
}

disk "/home/"{
	format = "%avail"
}

load {
    format = "%1min"
}

memory {
        format = "%used | %available"
        threshold_degraded = "1G"
        format_degraded = "MEMORY: %free"
}

tztime local {
        format = "%Y-%m-%d %H:%M:%S"
}
